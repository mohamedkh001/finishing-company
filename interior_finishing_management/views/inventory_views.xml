<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ifm_stock_item_tree" model="ir.ui.view">
        <field name="name">ifm.stock.item.tree</field>
        <field name="model">ifm.stock.item</field>
        <field name="arch" type="xml">
            <tree>
                <field name="project_id"/>
                <field name="product_id"/>
                <field name="category_id"/>
                <field name="quantity"/>
                <field name="used_quantity"/>
                <field name="remaining_quantity"/>
            </tree>
        </field>
    </record>

    <record id="action_ifm_stock_item" model="ir.actions.act_window">
        <field name="name">Project Inventory</field>
        <field name="res_model">ifm.stock.item</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="ifm_stock_menu" name="Project Inventory" parent="ifm_operations_menu" action="action_ifm_stock_item"/>
</odoo>

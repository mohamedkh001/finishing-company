<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ifm_expense_tree" model="ir.ui.view">
        <field name="name">ifm.expense.tree</field>
        <field name="model">ifm.expense</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="project_id"/>
                <field name="expense_type"/>
                <field name="amount"/>
                <field name="date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_ifm_expense_form" model="ir.ui.view">
        <field name="name">ifm.expense.form</field>
        <field name="model">ifm.expense</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,cancel"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="project_id"/>
                        <field name="expense_type"/>
                        <field name="amount"/>
                        <field name="date"/>
                        <field name="paid_from_custody"/>
                        <field name="custody_id" invisible="not paid_from_custody"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_ifm_payment_tree" model="ir.ui.view">
        <field name="name">ifm.payment.tree</field>
        <field name="model">ifm.payment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="project_id"/>
                <field name="amount"/>
                <field name="due_date"/>
                <field name="payment_date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_ifm_payment_form" model="ir.ui.view">
        <field name="name">ifm.payment.form</field>
        <field name="model">ifm.payment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_paid" type="object" string="Mark Paid" class="btn-primary" invisible="state == 'paid'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,paid,delayed"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="project_id"/>
                        <field name="amount"/>
                        <field name="due_date"/>
                        <field name="payment_date" readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_ifm_custody_tree" model="ir.ui.view">
        <field name="name">ifm.custody.tree</field>
        <field name="model">ifm.custody</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="project_id"/>
                <field name="employee_id"/>
                <field name="amount_assigned"/>
                <field name="amount_used"/>
                <field name="amount_remaining"/>
            </tree>
        </field>
    </record>

    <record id="action_ifm_expense" model="ir.actions.act_window">
        <field name="name">Expenses</field>
        <field name="res_model">ifm.expense</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="action_ifm_payment" model="ir.actions.act_window">
        <field name="name">Payments</field>
        <field name="res_model">ifm.payment</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="action_ifm_custody" model="ir.actions.act_window">
        <field name="name">Custody</field>
        <field name="res_model">ifm.custody</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="ifm_expense_menu" name="Expenses" parent="ifm_finance_menu" action="action_ifm_expense"/>
    <menuitem id="ifm_payment_menu" name="Payments" parent="ifm_finance_menu" action="action_ifm_payment"/>
    <menuitem id="ifm_custody_menu" name="Custody" parent="ifm_finance_menu" action="action_ifm_custody"/>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ifm_document_tree" model="ir.ui.view">
        <field name="name">ifm.document.tree</field>
        <field name="model">ifm.document</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_id"/>
                <field name="room"/>
                <field name="attachment_name"/>
            </list>
        </field>
    </record>

    <record id="view_ifm_document_form" model="ir.ui.view">
        <field name="name">ifm.document.form</field>
        <field name="model">ifm.document</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="project_id"/>
                        <field name="room"/>
                        <field name="attachment" filename="attachment_name"/>
                        <field name="attachment_name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ifm_document" model="ir.actions.act_window">
        <field name="name">Project Documents</field>
        <field name="res_model">ifm.document</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="ifm_document_menu" name="Project Documents" parent="ifm_documents_menu" action="action_ifm_document"/>
</odoo>

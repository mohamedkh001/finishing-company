<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ifm_project_tree" model="ir.ui.view">
        <field name="name">ifm.project.tree</field>
        <field name="model">ifm.project</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="unit_type"/>
                <field name="engineer_id"/>
                <field name="progress_percent" widget="progressbar"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_ifm_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">ifm.project</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_ifm_task" model="ir.actions.act_window">
        <field name="name">Tasks</field>
        <field name="res_model">ifm.task</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_ifm_project_form" model="ir.ui.view">
        <field name="name">ifm.project.form</field>
        <field name="model">ifm.project</field>
        <field name="arch" type="xml">
            <form string="Interior Project">
                <header>
                    <button name="action_activate" type="object" string="Activate" invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_done" type="object" string="Mark Done" invisible="state not in ('active', 'draft')"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state == 'cancel'"/>
                    <button name="action_open_dashboard" type="object" string="Project Dashboard" class="oe_highlight"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,done,cancel"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="action" class="oe_stat_button" icon="fa-tasks" name="%(action_ifm_task)d" context="{'search_default_project_id': id}">
                            <field name="task_ids" widget="statinfo" string="Tasks"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="code" readonly="1"/>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="lead_id"/>
                            <field name="address"/>
                            <field name="unit_type"/>
                            <field name="finishing_type"/>
                        </group>
                        <group>
                            <field name="apartment_size"/>
                            <field name="rooms_count"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="remaining_duration" readonly="1"/>
                            <field name="engineer_id"/>
                            <field name="supervisor_id"/>
                        </group>
                    </group>
                    <group string="Budget &amp; Profitability">
                        <group>
                            <field name="estimated_material_cost"/>
                            <field name="estimated_labor_cost"/>
                            <field name="estimated_total_cost" readonly="1"/>
                            <field name="variance_amount" readonly="1"/>
                        </group>
                        <group>
                            <field name="company_margin_percent"/>
                            <field name="total_expenses" readonly="1"/>
                            <field name="total_cost_with_margin" readonly="1"/>
                            <field name="profit_amount" readonly="1"/>
                            <field name="profit_percent" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Tasks">
                            <field name="task_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="assigned_employee_id"/>
                                    <field name="deadline"/>
                                    <field name="completion_percent"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="BOQ">
                            <field name="boq_line_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="total_cost"/>
                                    <field name="supplier_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Change Orders">
                            <field name="change_order_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="cost_impact"/>
                                    <field name="time_impact_days"/>
                                    <field name="date"/>
                                </list>
                            </field>
                        </page>
                        <page string="Contracts">
                            <field name="contract_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="total_value"/>
                                    <field name="payment_terms"/>
                                    <field name="deadline"/>
                                </list>
                            </field>
                        </page>
                        <page string="Chat">
                            <field name="message_ids" widget="mail_thread"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    

    <menuitem id="ifm_project_menu" name="Projects" parent="ifm_projects_menu" action="action_ifm_project" sequence="1"/>
    <menuitem id="ifm_task_menu" name="Tasks" parent="ifm_projects_menu" action="action_ifm_task" sequence="2"/>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ifm_procurement_request_tree" model="ir.ui.view">
        <field name="name">ifm.procurement.request.tree</field>
        <field name="model">ifm.procurement.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_id"/>
                <field name="requester_id"/>
                <field name="state"/>
                <field name="purchase_order_id"/>
            </list>
        </field>
    </record>
    <record id="view_ifm_procurement_request_form" model="ir.ui.view">
        <field name="name">ifm.procurement.request.form</field>
        <field name="model">ifm.procurement.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve" invisible="state != 'to_approve'" groups="interior_finishing_management.group_ifm_procurement_manager"/>
                    <button name="action_create_purchase_order" type="object" string="Create PO" invisible="state != 'approved'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state == 'cancel'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,to_approve,approved,done,cancel"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="project_id"/>
                        <field name="requester_id"/>
                        <field name="purchase_order_id" readonly="1"/>
                    </group>
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="name"/>
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="unit_price"/>
                            <field name="supplier_id"/>
                        </list>
                    </field>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_ifm_supplier_tree" model="ir.ui.view">
        <field name="name">ifm.supplier.tree</field>
        <field name="model">ifm.supplier</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="phone"/>
                <field name="rating"/>
            </list>
        </field>
    </record>

    <record id="action_ifm_procurement_request" model="ir.actions.act_window">
        <field name="name">Purchase Requests</field>
        <field name="res_model">ifm.procurement.request</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_ifm_supplier" model="ir.actions.act_window">
        <field name="name">Suppliers</field>
        <field name="res_model">ifm.supplier</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="ifm_procurement_request_menu" name="Purchase Requests" parent="ifm_operations_menu" action="action_ifm_procurement_request"/>
    <menuitem id="ifm_supplier_menu" name="Suppliers" parent="ifm_operations_menu" action="action_ifm_supplier"/>
</odoo>
